<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net7.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>dotnet-drmanhatan</PackageId>
    <Version>0.1.1</Version>
    <Authors>ÂnimaLab</Authors>
    <Company>ÂnimaLab</Company>
    <Description>Observable event runtime for .NET applications without telemetry vendor coupling.</Description>
    <PackageTags>drmanhatan;dotnet;observability;telemetry;events;websocket</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/animalab-netizen/dotnet-drmanhatan</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/animalab-netizen/dotnet-drmanhatan</PackageProjectUrl>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
